[{
  "department": "HR & People Operations",

  "common_questions": [
    {
      "id": "company_name",
      "question": "What is the company name?",
      "type": "text",
      "required": true
    },
    {
      "id": "hr_head",
      "question": "Who is the head of HR?",
      "type": "text"
    },
    {
      "id": "company_location",
      "question": "Where is the company headquartered?",
      "type": "text"
    },
    {
      "id": "work_policy",
      "question": "What is the company work model?",
      "type": "select",
      "options": ["Remote", "Hybrid", "On-site"]
    },
    {
      "id": "employee_strength",
      "question": "Total number of employees in the organization?",
      "type": "number"
    }
  ],

  "metadata_questions": [
    {
      "id": "document_title",
      "question": "Enter the document title",
      "type": "text"
    },
    {
      "id": "author_name",
      "question": "Who created this document?",
      "type": "text"
    },
    {
      "id": "approved_by",
      "question": "Who approved this document?",
      "type": "text"
    },
    {
      "id": "document_version",
      "question": "Document version",
      "type": "text"
    },
    {
      "id": "effective_date",
      "question": "Effective date of this document",
      "type": "date"
    }
  ],

  "document_questions": {

    "Offer Letter": [
      {
        "id": "candidate_name",
        "question": "Candidate full name",
        "type": "text",
        "required": true
      },
      {
        "id": "job_title",
        "question": "Job title offered",
        "type": "text"
      },
      {
        "id": "department",
        "question": "Department for the role",
        "type": "text"
      },
      {
        "id": "joining_date",
        "question": "Joining date",
        "type": "date"
      },
      {
        "id": "salary",
        "question": "Annual salary offered",
        "type": "text"
      },
      {
        "id": "probation_period",
        "question": "Probation period in months",
        "type": "number"
      }
    ],

    "Employment Contract": [
      {
        "id": "employee_name",
        "question": "Employee full name",
        "type": "text"
      },
      {
        "id": "contract_type",
        "question": "Contract type",
        "type": "select",
        "options": ["Full-Time", "Part-Time", "Contract"]
      },
      {
        "id": "contract_start",
        "question": "Contract start date",
        "type": "date"
      },
      {
        "id": "contract_end",
        "question": "Contract end date",
        "type": "date"
      }
    ],

    "Employee Handbook": [
      {
        "id": "company_values",
        "question": "List the company values",
        "type": "textarea"
      },
      {
        "id": "workplace_rules",
        "question": "Key workplace rules",
        "type": "textarea"
      },
      {
        "id": "benefits_summary",
        "question": "Employee benefits overview",
        "type": "textarea"
      }
    ],

    "HR Policy Manual": [
      {
        "id": "policy_scope",
        "question": "Scope of HR policies",
        "type": "textarea"
      },
      {
        "id": "policy_categories",
        "question": "List major HR policy categories",
        "type": "textarea"
      }
    ],

    "Onboarding Checklist": [
      {
        "id": "employee_name",
        "question": "New employee name",
        "type": "text"
      },
      {
        "id": "manager_name",
        "question": "Reporting manager name",
        "type": "text"
      },
      {
        "id": "equipment_required",
        "question": "Equipment required for onboarding",
        "type": "text"
      }
    ],

    "Performance Appraisal Form": [
      {
        "id": "employee_name",
        "question": "Employee name",
        "type": "text"
      },
      {
        "id": "review_period",
        "question": "Performance review period",
        "type": "text"
      },
      {
        "id": "performance_rating",
        "question": "Performance rating scale",
        "type": "text"
      },
      {
        "id": "manager_feedback",
        "question": "Manager feedback",
        "type": "textarea"
      }
    ],

    "Leave Policy Document": [
      {
        "id": "leave_types",
        "question": "Types of leave offered",
        "type": "textarea"
      },
      {
        "id": "annual_leave_days",
        "question": "Annual leave entitlement",
        "type": "number"
      }
    ],

    "Code of Conduct": [
      {
        "id": "ethical_guidelines",
        "question": "Key ethical guidelines",
        "type": "textarea"
      },
      {
        "id": "misconduct_policy",
        "question": "How misconduct is handled",
        "type": "textarea"
      }
    ],

    "Exit Interview Form": [
      {
        "id": "employee_name",
        "question": "Employee name",
        "type": "text"
      },
      {
        "id": "reason_for_leaving",
        "question": "Reason for leaving",
        "type": "textarea"
      },
      {
        "id": "feedback",
        "question": "Employee feedback",
        "type": "textarea"
      }
    ],

    "Training & Development Plan": [
      {
        "id": "training_objectives",
        "question": "Training objectives",
        "type": "textarea"
      },
      {
        "id": "skills_to_develop",
        "question": "Key skills to develop",
        "type": "textarea"
      },
      {
        "id": "training_duration",
        "question": "Training duration",
        "type": "text"
      }
    ]
  }
