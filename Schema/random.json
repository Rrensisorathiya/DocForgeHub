 {"auto_generated_metadata": {
      "generation_timestamp": {
        "field": "generation_timestamp",
        "type": "datetime",
        "auto_generate": true,
        "description": "When document generation started",
        "format": "ISO8601"
      },
      
      "generation_duration": {
        "field": "generation_duration",
        "type": "number",
        "unit": "seconds",
        "auto_calculate": true,
        "description": "Time taken to generate the document"
      },
      
      "llm_model": {
        "field": "llm_model",
        "type": "string",
        "auto_generate": true,
        "description": "LLM model used for generation",
        "example": "gpt-4-turbo"
      },
      
      "prompt_tokens": {
        "field": "prompt_tokens",
        "type": "integer",
        "auto_calculate": true,
        "description": "Number of tokens in the prompt"
      },
      
      "completion_tokens": {
        "field": "completion_tokens",
        "type": "integer",
        "auto_calculate": true,
        "description": "Number of tokens in the generated content"
      },
      
      "total_tokens": {
        "field": "total_tokens",
        "type": "integer",
        "auto_calculate": true,
        "description": "Total tokens used"
      },
      
      "generation_cost": {
        "field": "generation_cost",
        "type": "number",
        "currency": "USD",
        "auto_calculate": true,
        "description": "Estimated cost of document generation"
      },
      
      "quality_score": {
        "field": "quality_score",
        "type": "number",
        "min": 0,
        "max": 100,
        "auto_calculate": true,
        "description": "Automated quality assessment score",
        "criteria": [
          "All sections present",
          "Appropriate length",
          "Proper formatting",
          "Industry terminology used",
          "No placeholder text"
        ]
      },
      
      "completeness_check": {
        "field": "completeness_check",
        "type": "object",
        "auto_calculate": true,
        "description": "Section-by-section completeness validation",
        "structure": {
          "required_sections_present": "boolean",
          "missing_sections": "array",
          "section_word_counts": "object"
        }
      }
    },
    
    "notion_specific_metadata": {
      "notion_page_id": {
        "field": "notion_page_id",
        "type": "string",
        "required": false,
        "description": "Notion page ID after upload",
        "auto_populate": true,
        "example": "123e4567-e89b-12d3-a456-426614174000"
      },
      
      "notion_url": {
        "field": "notion_url",
        "type": "url",
        "required": false,
        "description": "Direct URL to document in Notion",
        "auto_populate": true,
        "example": "https://notion.so/workspace/page-id"
      },
      
      "upload_status": {
        "field": "upload_status",
        "type": "select",
        "required": false,
        "options": ["Pending", "Uploading", "Success", "Failed", "Retry"],
        "default": "Pending",
        "auto_update": true
      },
      
      "upload_attempts": {
        "field": "upload_attempts",
        "type": "integer",
        "required": false,
        "default": 0,
        "auto_increment": true,
        "description": "Number of upload attempts"
      },
      
      "last_upload_error": {
        "field": "last_upload_error",
        "type": "text",
        "required": false,
        "description": "Error message from last failed upload"
      }
    },
    
    "validation_rules": {
      "title_validation": {
        "rule": "Must be between 10 and 200 characters",
        "regex": "^.{10,200}$",
        "error_message": "Title must be between 10 and 200 characters"
      },
      
      "version_validation": {
        "rule": "Must follow semantic versioning (X.Y or X.Y.Z)",
        "regex": "^\\d+\\.\\d+(\\.\\d+)?$",
        "error_message": "Version must be in format X.Y or X.Y.Z"
      },
      
      "date_consistency": {
        "rule": "effective_date must be after approval_date",
        "validation_type": "cross_field",
        "fields": ["approval_date", "effective_date"]
      },
      
      "required_fields_by_status": {
        "Draft": ["title", "document_type", "department", "created_by"],
        "In Review": ["title", "document_type", "department", "created_by", "reviewer"],
        "Approved": ["title", "document_type", "department", "created_by", "reviewer", "approved_by", "approval_date"],
        "Published": ["title", "document_type", "department", "created_by", "reviewer", "approved_by", "approval_date", "effective_date"]
      }
    },
    
    "metadata_templates_by_department": {
      "HR & People Operations": {
        "default_tags": ["hr", "people", "employees"],
        "default_audience": ["All Employees", "Managers"],
        "default_confidentiality": "Internal",
        "required_compliance_tags": ["GDPR"]
      },
      
      "Legal & Compliance": {
        "default_tags": ["legal", "compliance", "governance"],
        "default_audience": ["Leadership", "Managers"],
        "default_confidentiality": "Confidential",
        "required_compliance_tags": ["SOC2", "ISO27001"]
      },
      
      "Sales & Customer Facing": {
        "default_tags": ["sales", "customer", "revenue"],
        "default_audience": ["All Employees"],
        "default_confidentiality": "Internal"
      },
      
      "Engineering & Operations": {
        "default_tags": ["engineering", "technical", "operations"],
        "default_audience": ["Technical Teams"],
        "default_confidentiality": "Internal",
        "required_compliance_tags": ["SOC2"]
      },
      
      "Security & Information Assurance": {
        "default_tags": ["security", "infosec", "cyber"],
        "default_audience": ["All Employees", "Technical Teams"],
        "default_confidentiality": "Strictly Confidential",
        "required_compliance_tags": ["ISO27001", "SOC2", "NIST"]
      }
    }
}