# 1. Initialize git in your project folder
cd ~/Desktop/Intership_work/Rensi
git init

# 2. Create .gitignore BEFORE first commit (very important)
cat > .gitignore << 'EOF'
# Environment & Secrets
.env
*.env

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Virtual Environment
venv/
env/
.venv/

# Database
*.sqlite3
*.db

# IDE
.vscode/settings.json
.idea/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
EOF


chroma_db/
*.bin

chroma_db/
cache/
*.bin
venv/
__pycache__/
.env

# 3. Connect to GitHub (create repo on GitHub first, then)
git remote add origin https://github.com/your-username/Rensi.git